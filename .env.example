# =============================================================================
# .env.example — Template de variáveis de ambiente
#
# Como usar:
#   cp .env.example .env
#   (edite o .env com suas credenciais reais)
#
# IMPORTANTE:
#   • Nunca commite o arquivo .env no Git (está no .gitignore)
#   • Este .env.example SIM pode ser commitado (só tem exemplos)
#   • Em produção, use variáveis do ambiente do servidor (Render, Railway, etc.)
# =============================================================================

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_NAME="PokéAPI"
APP_VERSION="2.0.0"
# DEBUG=true mostra queries SQL e logs detalhados — NUNCA use em produção!
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Formato: postgresql+asyncpg://usuario:senha@host:porta/nome_banco
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pokedb
# Versão síncrona — usada pelo Alembic para migrações
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/pokedb

# ── Redis ─────────────────────────────────────────────────────────────────────
# Banco 0 → cache da API
REDIS_URL=redis://localhost:6379/0
# Tempo de vida do cache em segundos (300 = 5 minutos)
CACHE_TTL=300

# ── Celery ────────────────────────────────────────────────────────────────────
# Banco 1 → fila de tarefas (broker)
CELERY_BROKER_URL=redis://localhost:6379/1
# Banco 2 → resultados das tarefas
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Apache Kafka ──────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_POKEMON=pokemon-events
KAFKA_CONSUMER_GROUP=poke-api-group

# ── ELK Stack — Logstash ──────────────────────────────────────────────────────
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5044
